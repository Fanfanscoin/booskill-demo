{
  "platform": "hermes",
  "name": "booskill",
  "display_name": "BossSkill 老板经营秘书",
  "version": "0.2.0-commercial-client",
  "entry": "SKILL.md",
  "install_source": "https://github.com/Fanfanscoin/booskill-demo.git",
  "description": "面向创业者和老板的经营秘书与训练顾问，支持客户、团队、任务、经营复盘和老板每日动作管理。免费版提供基础记录；授权版通过云端开放商业核心能力。",
  "license_contact": {
    "telegram": "fanfans555"
  },
  "recommended_bootstrap_prompt": "请读取 SKILL.md 作为主规则。先判断用户问题属于客户、团队、任务、经营指标、复盘、行业打法还是知识库沉淀，再给出可执行方案。建议必须包含动作、对象、负责人、时间、指标或验收标准中的至少三项。",
  "memory": {
    "mode": "local-first",
    "database": "sqlite",
    "schema_reference": "references/sqlite-database.md",
    "export_command": "python scripts/startup_os_db.py export --db startup_os.sqlite3"
  },
  "commands": {
    "init_database": "python scripts/startup_os_db.py init --db startup_os.sqlite3",
    "activate_license": "python scripts/startup_os_db.py activate-license --db startup_os.sqlite3 --license-key YOUR_LICENSE_KEY",
    "license_status": "python scripts/startup_os_db.py license-status --db startup_os.sqlite3",
    "assistant_action": "python scripts/startup_os_db.py assistant-action --db startup_os.sqlite3 --text \"今天帮我看看哪些客户需要跟进\"",
    "daily_brief": "python scripts/startup_os_db.py brief --db startup_os.sqlite3"
  },
  "features": [
    "customer_record",
    "team_record",
    "task_record",
    "boss_secretary",
    "customer_followup",
    "team_management",
    "daily_brief",
    "business_diagnosis",
    "industry_playbook",
    "knowledge_learning"
  ],
  "required_capabilities": [
    "read_markdown",
    "read_local_references",
    "run_local_python_optional",
    "sqlite_optional",
    "network_for_license_and_cloud_core"
  ],
  "commercial_notice": "本公开客户端仓库不包含商业核心源码。授权联系 Telegram: fanfans555。"
}
