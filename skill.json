{
  "name": "booskill",
  "display_name": "BossSkill 老板经营秘书",
  "version": "0.2.0-commercial-client",
  "description": "面向创业者和老板的经营秘书与训练顾问。免费版提供基础客户、团队、任务记录；授权版通过云端开放老板秘书智能判断、行业深度包、持续学习知识库和高级经营诊断。",
  "entry": "SKILL.md",
  "language": "zh-CN",
  "install_source": "https://github.com/Fanfanscoin/booskill-demo.git",
  "license_contact": {
    "telegram": "fanfans555"
  },
  "categories": [
    "startup",
    "business-coaching",
    "sales",
    "team-management",
    "customer-management",
    "executive-assistant"
  ],
  "resources": {
    "references": "references",
    "scripts": "scripts",
    "agent_metadata": "agents/openai.yaml"
  },
  "tools": [
    {
      "name": "startup_os_db",
      "type": "python-script",
      "path": "scripts/startup_os_db.py",
      "description": "BossSkill 客户端命令行工具，用于授权、基础 SQLite 记录导出，以及调用云端商业核心能力。"
    }
  ],
  "permissions": {
    "filesystem": "local-skill-directory-and-user-selected-db",
    "network": "required-for-license-and-cloud-core",
    "database": "sqlite-local"
  },
  "default_commands": {
    "init_database": "python scripts/startup_os_db.py init --db startup_os.sqlite3",
    "activate_license": "python scripts/startup_os_db.py activate-license --db startup_os.sqlite3 --license-key YOUR_LICENSE_KEY",
    "license_status": "python scripts/startup_os_db.py license-status --db startup_os.sqlite3",
    "export_memory": "python scripts/startup_os_db.py export --db startup_os.sqlite3",
    "assistant_action": "python scripts/startup_os_db.py assistant-action --db startup_os.sqlite3 --text \"今天帮我看看哪些客户需要跟进\"",
    "daily_brief": "python scripts/startup_os_db.py brief --db startup_os.sqlite3",
    "customer_review": "python scripts/startup_os_db.py review-customer --db startup_os.sqlite3 --text \"客户今天说预算太高，下周三再联系\"",
    "team_brief": "python scripts/startup_os_db.py team-brief --db startup_os.sqlite3"
  },
  "commercial_notice": "本公开客户端仓库不包含商业核心源码。商业核心能力由官方云端服务提供，授权联系 Telegram: fanfans555。"
}
